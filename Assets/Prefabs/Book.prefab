  m_text: "\u0414\u0435\u0432\u0443\u0448\u043A\u0430 \u0443\u043C\u0435\u0440\u043B\u0430
    \u043E\u0442 \u0437\u0430\u0442\u044F\u0436\u043D\u043E\u0439 \u043F\u043D\u0435\u0432\u043C\u043E\u043D\u0438\u0438
    \u0432 \u0431\u043E\u043B\u044C\u043D\u0438\u0447\u043D\u043E\u0439 \u043F\u0430\u043B\u0430\u0442\u0435.
