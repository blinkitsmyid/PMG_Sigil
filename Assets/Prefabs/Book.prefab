    \u0441\u043C\u043E\u0442\u0440\u0435\u043B\u0430 \u0432 \u043E\u043A\u043D\u043E
    \u043D\u0430 \u0446\u0432\u0435\u0442\u0443\u0449\u0438\u0435 \u0434\u0435\u0440\u0435\u0432\u044C\u044F
    \u0438 \u0448\u0435\u043F\u0442\u0430\u043B\u0430, \u0447\u0442\u043E \u0432\u044B\u0439\u0434\u0435\u0442
    \u0433\u0443\u043B\u044F\u0442\u044C \u043A\u0430\u043A \u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u0442\u0430\u043D\u0435\u0442 \u0447\u0443\u0442\u044C \u043B\u0435\u0433\u0447\u0435."
